        <span style="font-size:11px;font-weight:700;color:white;">LTE</span>
        <div class="battery" style="color:white;"><div class="battery-fill"></div></div>
      </div>
    </div>

    <div class="success-content">
      <div class="failed-icon">⏰</div>
      <div class="failed-title">Gather<br>expired</div>
      <div class="failed-sub">The deadline passed before all contributors paid. No charges were made — everyone has been refunded.</div>

      <div class="receipt-card">
        <div class="receipt-row">
          <span class="receipt-label">Gift</span>
          <span class="receipt-val">Nike Air Max 90</span>
        </div>
        <div class="receipt-row">
          <span class="receipt-label">Raised</span>
          <span class="receipt-val">€108 / €180</span>
        </div>
        <div class="receipt-row">
          <span class="receipt-label">Refund status</span>
          <span class="receipt-val">✓ Refunded</span>
        </div>
      </div>

      <button class="retry-btn" onclick="goTo('screen-setup')">Try again →</button>
      <button class="done-btn" style="background:rgba(255,255,255,0.15);color:white;" onclick="goTo('screen-home')">Back to Wolt</button>
    </div>
  </div>

</div><!-- end phone-shell -->

<script>
  let peopleCount = 5;
  const totalPrice = 180;

  function goTo(screenId) {
    const current = document.querySelector('.screen.active');
    const next = document.getElementById(screenId);
    if (!next || current === next) return;
    current.classList.remove('active');
    next.classList.add('active', 'slide-in');
    next.addEventListener('animationend', () => next.classList.remove('slide-in'), { once: true });
    next.scrollTop = 0;
  }

  function goBack(screenId) {
    const current = document.querySelector('.screen.active');
    const prev = document.getElementById(screenId);
    if (!prev || current === prev) return;
    current.classList.remove('active');
    prev.classList.add('active', 'slide-back');
    prev.addEventListener('animationend', () => prev.classList.remove('slide-back'), { once: true });
    prev.scrollTop = 0;
  }

  function changePeople(delta) {
    peopleCount = Math.max(2, Math.min(10, peopleCount + delta));
    document.getElementById('people-count').textContent = peopleCount;
    const share = Math.ceil(totalPrice / peopleCount);
    document.getElementById('split-amount').textContent = '€' + share;
  }

  function copyLink(el) {
    const btn = document.getElementById('copy-btn');
    btn.textContent = 'Copied!';
    btn.style.color = '#00C896';
    setTimeout(() => {
      btn.textContent = 'Copy';
      btn.style.color = '';
    }, 2000);
  }

  function selectPM(el) {
    document.querySelectorAll('.pm-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
  }

  // Animate progress bar when share screen is shown
  const observer = new MutationObserver(() => {
    if (document.getElementById('screen-share').classList.contains('active')) {
      setTimeout(() => {
        document.getElementById('progress-bar').style.width = '40%';
      }, 300);
    }
  });
  observer.observe(document.getElementById('screen-share'), { attributes: true });

  // Set default deadline to 7 days from now
  const d = new Date();
  d.setDate(d.getDate() + 7);
  document.getElementById('deadline-input').value = d.toISOString().split('T')[0];
</script>

</body>
</html>
